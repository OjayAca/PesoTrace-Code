PORT=5000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-secret
# JWT_SECRET is required. The server will fail to start without it.
MYSQL_STORE=true
# Set MYSQL_STORE=memory only if you explicitly want the bundled JSON snapshot during local development.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=pesotrace
MYSQL_CONNECT_TIMEOUT=5000
