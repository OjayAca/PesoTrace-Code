PORT=5000
CLIENT_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173
JWT_SECRET=change-this-secret-to-at-least-32-characters
# JWT_SECRET is required and must be at least 32 characters. Use high entropy in production.
EMAIL_PROVIDER=brevo
EMAIL_FROM="PesoTrace <no-reply@pesotrace.com>"
# Brevo SMTP settings. In Brevo, create an SMTP key and use it as SMTP_PASS.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=ab5c16001@smtp-brevo.com
SMTP_PASS=WyDfH1gtMSn6AIPK
SMTP_PASS=your-brevo-smtp-key
SMTP_SECURE=false
# Optional Resend settings if EMAIL_PROVIDER=resend.
RESEND_API_KEY=change-me
# Email delivery is required in production for password reset links.
MYSQL_STORE=true
# Production uses MySQL by default. Set MYSQL_STORE=memory only for local demos or explicit snapshots.
# In production, MYSQL_STORE=memory also requires ALLOW_MEMORY_STORE=true.
ALLOW_MEMORY_STORE=false
BCRYPT_ROUNDS=12
# BCRYPT_ROUNDS accepts 10-15. Production defaults to 12 when unset.
# Auth endpoints are rate-limited in the API. Tune defaults in code before deployment if needed.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=pesotrace
MYSQL_CONNECT_TIMEOUT=5000
# Railway provides PORT automatically. Do not set PORT in Railway production variables.
